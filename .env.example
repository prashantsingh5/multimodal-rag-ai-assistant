# Multimodal RAG AI Assistant — environment variables
# Copy this to .env and fill in your real keys. Never commit .env.

# ── LLM & Embedding providers ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=                          # optional — leave blank if using Gemini

# ── Vector store ────────────────────────────────────────────────────────────
# "faiss" (default, no server needed) or "chroma" (requires chromadb server)
VECTOR_STORE_BACKEND=faiss

# ── Application ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
